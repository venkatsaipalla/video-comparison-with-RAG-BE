# Supabase Postgres (used for ADK DatabaseSessionService)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# OpenAI (routed via LiteLLM)
OPENAI_API_KEY=sk-...

# Model tiers (OpenAI GPT-5.x light variants for now)
MODEL_ROUTER=openai/gpt-5-nano
MODEL_WORKER=openai/gpt-5-mini
MODEL_SYNTH=openai/gpt-5-mini

# Retrieval repo (separate service that owns vector DB + GPU)
RETRIEVAL_BASE_URL=http://localhost:9000
# Must match RETRIEVAL_API_KEY in the GPU repo. Sent as X-API-Key on every call.
RETRIEVAL_API_KEY=change-me-to-match-the-gpu-repo

# Auth — clients must send this in the X-API-Key header on /init and /chat
BACKEND_API_KEY=change-me-to-a-long-random-string

# App
APP_NAME=video-rag-brain
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000