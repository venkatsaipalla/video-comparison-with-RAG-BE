# OpenAI (LiteLLM)
OPENAI_API_KEY=sk-...

# Auth — required on /init and /chat (header: X-API-Key)
BACKEND_API_KEY=change-me-to-a-long-random-string

# GPU retrieval service
RETRIEVAL_BASE_URL=https://your-gpu-service.example.com
RETRIEVAL_API_KEY=change-me-to-match-gpu-repo

# ADK session store — use Postgres on Render; SQLite OK for local dev only
ADK_DATABASE_URL=sqlite:///./gadk.db
# ADK_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# CORS (comma-separated; include your Vercel URL in production)
CORS_ORIGINS=http://localhost:3000

# App
APP_NAME=video-rag-brain
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000

# Model tiers
MODEL_ROUTER=openai/gpt-5-nano
MODEL_WORKER=openai/gpt-5-mini
MODEL_SYNTH=openai/gpt-5-mini
