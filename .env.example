# OpenAI (LiteLLM)
OPENAI_API_KEY=sk-...

# Postgres — app tables (users, comparisons, messages) and ADK tables
# (sessions, events, app_states, user_states, adk_internal_metadata) in one database
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Auth — required on /init and /chat (header: X-API-Key)
BACKEND_API_KEY=change-me-to-a-long-random-string

# Google OAuth — same Client ID as NextAuth on the frontend
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# GPU retrieval service
RETRIEVAL_BASE_URL=https://your-gpu-service.example.com
RETRIEVAL_API_KEY=change-me-to-match-gpu-repo

# CORS (comma-separated; include your Vercel URL in production)
CORS_ORIGINS=http://localhost:3000

# App
APP_NAME=video-rag-brain
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000

# Model tiers
MODEL_ROUTER=openai/gpt-5.1-nano
MODEL_WORKER=openai/gpt-5.1-mini
MODEL_SYNTH=openai/gpt-5.1-mini
